# Release Portal V3 环境变量配置模板
# 复制此文件为 .env 并修改相应的值

# ================================
# 数据库配置
# ================================
# SQLite 数据库文件路径
RELEASE_PORTAL_DB=./data/portal.db

# ================================
# 安全配置
# ================================
# JWT 密钥（必须修改！）
# 生成方法: python3 -c "import secrets; print(secrets.token_hex(32))"
RELEASE_PORTAL_SECRET=change-this-to-a-random-secret-key-in-production

# Token 过期时间（小时）
RELEASE_PORTAL_TOKEN_EXPIRY_HOURS=24

# ================================
# Web 服务配置
# ================================
# Flask 环境（development / production）
FLASK_ENV=production

# Flask 调试模式（0 / 1）
FLASK_DEBUG=0

# 绑定地址
FLASK_HOST=0.0.0.0

# 绑定端口
FLASK_PORT=5000

# ================================
# 存储配置
# ================================
# 存储目录
RELEASE_PORTAL_STORAGE_DIR=./storage

# 临时文件目录
RELEASE_PORTAL_TEMP_DIR=./temp

# 最大上传大小（MB）
RELEASE_PORTAL_MAX_UPLOAD_SIZE=500

# ================================
# 日志配置
# ================================
# 日志目录
RELEASE_PORTAL_LOG_DIR=./logs

# 日志级别（DEBUG / INFO / WARNING / ERROR / CRITICAL）
RELEASE_PORTAL_LOG_LEVEL=INFO

# ================================
# 备份配置
# ================================
# 备份目录
RELEASE_PORTAL_BACKUP_DIR=./backups

# 备份保留天数
RELEASE_PORTAL_BACKUP_RETENTION_DAYS=30

# ================================
# 测试配置（开发环境）
# ================================
# 启用发布前测试（true / false）
RELEASE_PORTAL_ENABLE_TESTS=false

# 默认测试级别（critical / all / api / integration）
RELEASE_PORTAL_TEST_LEVEL=critical

# ================================
# 性能配置
# ================================
# Gunicorn Worker 数量
# 推荐值: (2 × CPU核心数) + 1
GUNICORN_WORKERS=4

# Gunicorn 线程数
GUNICORN_THREADS=2

# 请求超时时间（秒）
GUNICORN_TIMEOUT=120

# ================================
# CORS 配置（如果需要）
# ================================
# 允许的跨域来源（逗号分隔）
# CORS_ORIGINS=http://localhost:3000,https://example.com
